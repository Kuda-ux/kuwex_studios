# =====================================================
# KuWeX Studios — Environment Variables
# Copy this file to .env.local and fill in real values
# =====================================================

# ============ TURSO DATABASE (Dashboard) ============
# Get these from https://turso.tech (FREE account)
# 1. Sign up at turso.tech
# 2. Create a new database
# 3. Copy the "Database URL" and "Auth Token" here
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# ============ OPENAI (AI tender features - optional) ============
# Only needed if you use the AI tender scraper
OPENAI_API_KEY=sk-your-key-here

# ============ SITE URL ============
NEXT_PUBLIC_SITE_URL=https://kuwexstudios.co.zw
